from __future__ import annotations

from dataclasses import dataclass
from datetime import datetime
import heapq
from typing import List, Optional


def parse_time_to_key(time_str: str) -> tuple[int, int, int, int]:
    """
    Parse time string like '10:00:00.005' into a comparable tuple.
    """
    dt = datetime.strptime(time_str, "%H:%M:%S.%f")
    return (dt.hour, dt.minute, dt.second, dt.microsecond)


@dataclass
class Order:
    order_id: str
    create_time: str
    side: str
    price: float
    quantity: int

    def time_key(self) -> tuple[int, int, int, int]:
        return parse_time_to_key(self.create_time)


@dataclass
class Execution:
    execution_id: int
    price: float
    quantity: int
    sell_order_id: str
    buy_order_id: str


class PriceTimePriorityMatchingEngine:
    """
    Matching engine with:
    - Buy side priority: higher price first, then earlier time
    - Sell side priority: lower price first, then earlier time
    - If crossing occurs, execution price = resting order's price
    - Execution ID starts from 1 and increments sequentially
    """

    def __init__(self) -> None:
        self._buy_heap: List[tuple[float, tuple[int, int, int, int], int, Order]] = []
        self._sell_heap: List[tuple[float, tuple[int, int, int, int], int, Order]] = []
        self._next_execution_id = 1
        self._arrival_seq = 0

    def process_order(self, order: Order) -> List[Execution]:
        """
        Accept one new order and return the executions generated by it.
        """
        self._validate_order(order)
        executions: List[Execution] = []

        if order.side.lower() == "buy":
            executions.extend(self._process_buy(order))
        elif order.side.lower() == "sell":
            executions.extend(self._process_sell(order))
        else:
            raise ValueError(f"Invalid side: {order.side}")

        return executions

    def _process_buy(self, incoming: Order) -> List[Execution]:
        executions: List[Execution] = []

        while incoming.quantity > 0 and self._sell_heap:
            best_sell_price, _, _, resting_sell = self._sell_heap[0]

            if best_sell_price > incoming.price:
                break

            heapq.heappop(self._sell_heap)

            traded_qty = min(incoming.quantity, resting_sell.quantity)

            executions.append(
                Execution(
                    execution_id=self._next_execution_id,
                    price=resting_sell.price,  # resting order price
                    quantity=traded_qty,
                    sell_order_id=resting_sell.order_id,
                    buy_order_id=incoming.order_id,
                )
            )
            self._next_execution_id += 1

            incoming.quantity -= traded_qty
            resting_sell.quantity -= traded_qty

            if resting_sell.quantity > 0:
                heapq.heappush(
                    self._sell_heap,
                    (
                        resting_sell.price,
                        resting_sell.time_key(),
                        self._next_seq(),
                        resting_sell,
                    ),
                )

        if incoming.quantity > 0:
            heapq.heappush(
                self._buy_heap,
                (
                    -incoming.price,
                    incoming.time_key(),
                    self._next_seq(),
                    incoming,
                ),
            )

        return executions

    def _process_sell(self, incoming: Order) -> List[Execution]:
        executions: List[Execution] = []

        while incoming.quantity > 0 and self._buy_heap:
            neg_best_buy_price, _, _, resting_buy = self._buy_heap[0]
            best_buy_price = -neg_best_buy_price

            if best_buy_price < incoming.price:
                break

            heapq.heappop(self._buy_heap)

            traded_qty = min(incoming.quantity, resting_buy.quantity)

            executions.append(
                Execution(
                    execution_id=self._next_execution_id,
                    price=resting_buy.price,  # resting order price
                    quantity=traded_qty,
                    sell_order_id=incoming.order_id,
                    buy_order_id=resting_buy.order_id,
                )
            )
            self._next_execution_id += 1

            incoming.quantity -= traded_qty
            resting_buy.quantity -= traded_qty

            if resting_buy.quantity > 0:
                heapq.heappush(
                    self._buy_heap,
                    (
                        -resting_buy.price,
                        resting_buy.time_key(),
                        self._next_seq(),
                        resting_buy,
                    ),
                )

        if incoming.quantity > 0:
            heapq.heappush(
                self._sell_heap,
                (
                    incoming.price,
                    incoming.time_key(),
                    self._next_seq(),
                    incoming,
                ),
            )

        return executions

    def get_buy_book(self) -> List[Order]:
        """
        Return current buy book in display priority order.
        """
        copied = sorted(self._buy_heap, key=lambda x: (x[0], x[1], x[2]))
        return [item[3] for item in copied]

    def get_sell_book(self) -> List[Order]:
        """
        Return current sell book in display priority order.
        """
        copied = sorted(self._sell_heap, key=lambda x: (x[0], x[1], x[2]))
        return [item[3] for item in copied]

    def _validate_order(self, order: Order) -> None:
        if not order.order_id:
            raise ValueError("order_id must be non empty")
        if order.side.lower() not in {"buy", "sell"}:
            raise ValueError("side must be Buy or Sell")
        if order.price <= 0:
            raise ValueError("price must be positive")
        if order.quantity <= 0:
            raise ValueError("quantity must be positive")
        parse_time_to_key(order.create_time)

    def _next_seq(self) -> int:
        """
        Stable tie breaker when timestamps are identical.
        """
        self._arrival_seq += 1
        return self._arrival_seq



def format_execs(execs):
    if not execs:
        return "None"
    parts = []
    for e in execs:
        parts.append(
            f"ExecID: {e.execution_id} Price: ${e.price:.2f} Quantity: {e.quantity} "
            f"Buy OrderID: {e.buy_order_id} Sell OrderID: {e.sell_order_id}"
        )
    return " ; ".join(parts)


def format_book(book):
    if not book:
        return ""
    return " ".join(f"{o.order_id} ({o.quantity})" for o in book)


engine = PriceTimePriorityMatchingEngine()

orders = [
    Order("Buy-1",  "10:00:00.000", "Buy",  9.99, 300),
    Order("Buy-2",  "10:00:00.000", "Buy", 10.00, 200),
    Order("Sell-1", "10:00:00.005", "Sell", 10.01, 300),
    Order("Sell-2", "10:00:00.005", "Sell", 10.00, 100),
    Order("Sell-3", "10:00:00.010", "Sell",  9.99, 200),
    Order("Sell-4", "10:00:00.015", "Sell", 10.00, 200),
    Order("Buy-3",  "10:00:00.010", "Buy", 10.00, 300),
    Order("Sell-5", "10:00:00.020", "Sell", 10.01, 500),
    Order("Buy-4",  "10:00:00.020", "Buy", 10.01, 200),
    Order("Buy-5",  "10:00:00.020", "Buy", 10.01, 300),
]

for order in orders:
    execs = engine.process_order(order)
    print(order.order_id)
    print("Executions:", format_execs(execs))
    print("Buy Book   :", format_book(engine.get_buy_book()))
    print("Sell Book  :", format_book(engine.get_sell_book()))
    print("-" * 60)
